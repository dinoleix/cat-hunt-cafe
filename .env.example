# Backend selection: "local" (default, localStorage) or "firebase"
VITE_BACKEND=local

# Admin panel password (guards the /admin UI). Change before deploying!
VITE_ADMIN_PASSWORD=catcafe

# ---- Only needed when VITE_BACKEND=firebase (also run: npm i firebase) ----
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_SENDER_ID=
VITE_FB_APP_ID=
